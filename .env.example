# Publishable API key for the Medusa backend. Required for the storefront to function.
# Learn how to create a publishable key: https://docs.medusajs.com/v2/resources/storefront-development/publishable-api-keys
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_your_publishable_api_key_here

# URL of the Medusa backend API server
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000

# Default region code to use for the storefront
NEXT_PUBLIC_DEFAULT_REGION=tr

# Base URL of the storefront (used for generating absolute URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:8000

# Stripe publishable key for payment processing (optional)
NEXT_PUBLIC_STRIPE_KEY=

# Medusa Cloud S3 bucket hostname (optional)
MEDUSA_CLOUD_S3_HOSTNAME=

# Medusa Cloud S3 bucket path (optional)
MEDUSA_CLOUD_S3_PATHNAME=

# Node environment
NODE_ENV=development
